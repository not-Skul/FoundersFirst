FROM python:3.11-slim

WORKDIR /app

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install system dependency: libpq for psycopg (required by langgraph-checkpoint-postgres)
RUN apt-get update && apt-get install -y libpq-dev && rm -rf /var/lib/apt/lists/*

# Install dependencies first — this layer is cached unless pyproject.toml changes
COPY pyproject.toml .
RUN uv sync

# Copy source code after dependencies to maximize cache reuse
COPY . .

EXPOSE 7000

# Production server: 2 workers, no --reload
CMD ["uv", "run", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "7000", "--workers", "2"]
