FROM python:3.11-slim

WORKDIR /app

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install dependencies first — this layer is cached unless pyproject.toml changes
COPY pyproject.toml .
RUN uv sync

# Copy source code after dependencies to maximize cache reuse
COPY . .

EXPOSE 5000

# Production server: gunicorn with 2 workers
# --timeout 310 keeps workers alive for the AI backend's 300s response window
CMD ["uv", "run", "gunicorn", "main:app", "--bind", "0.0.0.0:5000", "--workers", "2", "--timeout", "310"]
